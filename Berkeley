import java.io.*; 
import java.net.*; 
import java.util.*; 
 
public class BerkeleyServer { 
    static final int PORT = 5000; 
 
    public static void main(String[] args) throws Exception { 
        ServerSocket serverSocket = new ServerSocket(PORT); 
        System.out.println("Master started..."); 
 
        List<Long> clientTimes = new ArrayList<>(); 
        List<Socket> clients = new ArrayList<>(); 
 
        // Accept 3 clients 
        for (int i = 0; i < 3; i++) { 
            Socket socket = serverSocket.accept(); 
            clients.add(socket); 
 
            DataInputStream in = new DataInputStream(socket.getInputStream()); 
            long clientTime = in.readLong(); 
 
            clientTimes.add(clientTime); 
            System.out.println("Received time: " + clientTime); 
        } 
 
        long masterTime = System.currentTimeMillis(); 
        clientTimes.add(masterTime); 
 
        // Compute average 
        long sum = 0; 
        for (long t : clientTimes) sum += t; 
 
        long avg = sum / clientTimes.size(); 
        System.out.println("Average time: " + avg); 
 
        // Send adjustment 
        for (int i = 0; i < clients.size(); i++) { 
            Socket s = clients.get(i); 
            DataOutputStream out = new DataOutputStream(s.getOutputStream()); 
 
            long offset = avg - clientTimes.get(i); 
            out.writeLong(offset); 
 
            System.out.println("Sent offset: " + offset); 
        } 
 
        serverSocket.close(); 
    } 
}

